# Copy to .env and adjust values for local development.
# Never commit secrets.

# -----------------------------------------------------------------------------
# Database (required for M1+)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio_red?schema=public"
DIRECT_URL="postgresql://portfolio:portfolio@localhost:5432/portfolio_red?schema=public"

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV="development"

# -----------------------------------------------------------------------------
# AI (M3+)
# -----------------------------------------------------------------------------
AI_PROVIDER="openai"
AI_MODEL="gpt-4o"
AI_MAX_TOKENS="2048"
OPENAI_API_KEY=""
EMBEDDING_MODEL="text-embedding-3-small"

# -----------------------------------------------------------------------------
# Admin (M4+)
# -----------------------------------------------------------------------------
AUTH_SECRET=""
ADMIN_EMAIL=""
