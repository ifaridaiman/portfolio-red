{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "GITHUB_PAGES",
    "NEXT_PUBLIC_STATIC_EXPORT",
    "DATABASE_URL",
    "DIRECT_URL",
    "AI_PROVIDER",
    "AI_MODEL",
    "AI_MAX_TOKENS",
    "OPENAI_API_KEY",
    "EMBEDDING_MODEL",
    "AUTH_SECRET",
    "ADMIN_EMAIL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "out/**", "node_modules/.prisma/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
